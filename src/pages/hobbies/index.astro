---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = await getCollection('hobbies');
const photos = await getCollection('photos');
const entries = await Promise.all(
  posts.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);
const sortedEntries = entries.sort((a, b) => {
  const dateA = Date.parse(a.entry.data.date || '');
  const dateB = Date.parse(b.entry.data.date || '');
  if (Number.isNaN(dateA) || Number.isNaN(dateB)) {
    return 0;
  }
  return dateB - dateA;
});

const fallbackPhoto = '/photos/hat.jpeg';
const getRandomPhotoForEntry = (seed: string) => {
  if (!photos.length) return fallbackPhoto;
  const hash = Array.from(seed).reduce((acc, ch) => acc + ch.charCodeAt(0), 0);
  return photos[hash % photos.length]?.data.image ?? fallbackPhoto;
};
---

<Base title="Hobbies – Elrich Chen">
  <div class="mb-6">
    <a href="/" class="back-home-link">← Back to home</a>
  </div>
  <h1 class="page-title text-xl font-semibold mb-4">Hobbies</h1>

  <div class="hobby-grid">
    {sortedEntries.map(({ entry, Content }) => (
      <details class="hobby-card hobby-details">
        <summary class="hobby-summary-toggle">
          <div class="hobby-head">
            <div>
              <h2 class="hobby-title">{entry.data.title}</h2>
              <p class="hobby-date">{entry.data.date}</p>
            </div>
          </div>
          {entry.data.summary && <p class="hobby-summary">{entry.data.summary}</p>}
          {entry.data.tags?.length > 0 && (
            <div class="hobby-tags hobby-tags-bottom">
              {entry.data.tags.map((tag: string) => (
                <span class="hobby-tag">{tag}</span>
              ))}
            </div>
          )}
          <span class="hobby-toggle" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 8l4 4 4-4" />
            </svg>
          </span>
        </summary>
        <div class="hobby-body">
          <img
            src={getRandomPhotoForEntry(entry.slug)}
            alt={`Hobby visual for ${entry.data.title}`}
            class="hobby-body-photo"
            loading="lazy"
            decoding="async"
          />
          <Content />
        </div>
      </details>
    ))}
  </div>
</Base>

<style>
  .page-title {
    color: #fff;
  }

  .hobby-grid {
    display: grid;
    gap: 1.2rem;
  }

  .hobby-card {
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    padding: 1.2rem 1.4rem;
    background: rgba(255, 255, 255, 0.16);
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.14);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: border-color 0.35s ease, box-shadow 0.35s ease, transform 0.35s ease;
  }

  :global(html.dark) .hobby-card {
    background: rgba(10, 10, 10, 0.58);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.42);
  }

  .hobby-card[open] {
    border-color: rgba(var(--border), 0.3);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.12);
  }

  .hobby-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .hobby-title {
    margin: 0;
    font-size: 1.05rem;
    color: #fff;
  }

  .hobby-date {
    margin: 0.3rem 0 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.82);
  }

  .hobby-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .hobby-tags-bottom {
    align-self: flex-start;
    justify-content: flex-start;
    margin-top: 0.6rem;
  }

  .hobby-tag {
    font-size: 0.7rem;
    padding: 0.24rem 0.58rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  .hobby-summary-toggle {
    cursor: pointer;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: inherit;
    border: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-right: 2.5rem;
    transition: color 0.35s ease, border-color 0.35s ease;
  }

  .hobby-summary-toggle:hover {
    color: rgb(var(--fg));
  }

  .hobby-summary-toggle::-webkit-details-marker {
    display: none;
  }

  .hobby-summary-toggle::marker {
    content: '';
  }

  .hobby-summary {
    margin: 0.7rem 0 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: #fff;
  }

  .hobby-toggle {
    position: absolute;
    top: -0.2rem;
    right: 0;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.26);
    color: rgba(255, 255, 255, 0.9);
    transition: transform 0.35s ease, color 0.35s ease, background 0.35s ease, border-color 0.35s ease;
  }

  .hobby-toggle svg {
    width: 16px;
    height: 16px;
  }

  .hobby-card[open] .hobby-toggle {
    transform: rotate(180deg);
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.34);
  }

  .hobby-body {
    margin-top: 0.9rem;
    font-size: 0.9rem;
    color: #161616;
    line-height: 1.65;
    background: rgba(255, 255, 255, 0.94);
    border-radius: 12px;
    padding: 0.9rem 0.95rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.38s ease, transform 0.38s ease;
  }

  .hobby-card[open] .hobby-body {
    opacity: 1;
    transform: translateY(0);
  }

  :global(html.dark) .hobby-body {
    background: rgba(12, 12, 12, 0.88);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.16);
  }

  .hobby-body-photo {
    width: clamp(110px, 24vw, 150px);
    height: clamp(110px, 24vw, 150px);
    object-fit: cover;
    border-radius: 10px;
    float: left;
    margin: 0.2rem 0.85rem 0.45rem 0;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .hobby-body :global(p) {
    margin: 0 0 0.9rem;
  }

  .hobby-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .hobby-body::after {
    content: '';
    display: block;
    clear: both;
  }

  .hobby-body :global(a) {
    color: #111;
    text-decoration: underline;
  }

  :global(html.dark) .hobby-body :global(a) {
    color: #fff;
  }

  @media (max-width: 640px) {
    .hobby-body-photo {
      float: none;
      display: block;
      margin: 0 0 0.75rem;
      width: 100%;
      height: 180px;
    }
  }

  @media (max-width: 480px) {
    .hobby-grid {
      gap: 0.9rem;
    }

    .hobby-card {
      border-radius: 14px;
      padding: 1rem 0.95rem;
    }

    .hobby-summary-toggle {
      gap: 0.3rem;
      padding-right: 2.85rem;
    }

    .hobby-title {
      font-size: 1rem;
      line-height: 1.35;
    }

    .hobby-date {
      margin-top: 0.25rem;
      font-size: 0.69rem;
      letter-spacing: 0.1em;
    }

    .hobby-summary {
      margin-top: 0.55rem;
      font-size: 0.9rem;
      line-height: 1.55;
    }

    .hobby-tags-bottom {
      margin-top: 0.5rem;
      gap: 0.3rem;
    }

    .hobby-tag {
      font-size: 0.68rem;
      padding: 0.22rem 0.52rem;
    }

    .hobby-toggle {
      width: 44px;
      height: 44px;
      top: -0.15rem;
    }

    .hobby-toggle svg {
      width: 18px;
      height: 18px;
    }

    .hobby-body {
      margin-top: 0.75rem;
      padding: 0.8rem;
      font-size: 0.88rem;
      line-height: 1.6;
    }

    .hobby-body-photo {
      height: 165px;
      margin-bottom: 0.65rem;
    }
  }
</style>
