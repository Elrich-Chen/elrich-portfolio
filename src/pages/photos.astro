---
import Base from '../layouts/Base.astro';
import TiltedCard from '../components/TiltedCard.astro';
import { getCollection } from 'astro:content';

const allPhotos = await getCollection('photos');
---

<Base title="Photos – Elrich Chen">
  <div class="mb-6">
    <a href="/" class="back-home-link">← Back to home</a>
  </div>
  <h1 class="page-title text-xl font-semibold mb-8">Photos</h1>

  {allPhotos.length === 0 ? (
    <p class="text-neutral-600">No photos yet. Add your photos to src/content/photos/</p>
  ) : (
    <div class="photo-grid">
      {allPhotos.map((photo) => (
        <div class="photo-cell">
          <TiltedCard
            imageSrc={photo.data.image}
            altText={photo.data.caption}
            captionText={[photo.data.caption, photo.data.location].filter(Boolean).join(' · ')}
            containerHeight="100%"
            containerWidth="100%"
            imageHeight="100%"
            imageWidth="100%"
            rotateAmplitude={12}
            scaleOnHover={1.06}
            showMobileWarning={false}
            showTooltip={true}
          />
          <div class="photo-meta">
            <p class="photo-caption">{photo.data.caption}</p>
            <div class="photo-sub">
              <span>{photo.data.date}</span>
              {photo.data.location && (
                <>
                  <span class="dot">·</span>
                  <span>{photo.data.location}</span>
                </>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</Base>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    padding-top: 1rem;
    padding-bottom: 3rem;
    width: 100%;
    max-width: 1000px;
    margin-inline: auto;
  }

  .page-title {
    color: #fff;
  }

  @media (min-width: 640px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.25rem;
    }
  }

  .photo-cell {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .photo-cell :global(.tc-figure) {
    height: auto !important;
  }

  .photo-cell :global(.tc-inner) {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 1 / 1;
  }

  .photo-meta {
    text-align: center;
  }

  .photo-caption {
    font-family: 'Reenie Beanie', cursive;
    font-size: 1.4rem;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 0.2rem;
  }

  .photo-sub {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: #fff;
    font-weight: 500;
    opacity: 0.9;
  }

  .dot {
    color: #fff;
    opacity: 0.7;
  }
</style>
