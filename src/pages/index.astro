---
import Base from '../layouts/Base.astro';
import Basketball from '../components/Basketball.astro';
import { getEntry, getCollection } from 'astro:content';

const highlights    = await getEntry('highlights', 'home');
const testimonials  = await getCollection('testimonials');

// Ensure at least 6 cards for the carousel
const carouselItems = (() => {
  if (testimonials.length === 0) return [];
  if (testimonials.length >= 6) return testimonials;
  const repeated: typeof testimonials = [];
  while (repeated.length < 6) repeated.push(...testimonials);
  return repeated.slice(0, 6);
})();

// ── Company link map ──────────────────────────────────────────────────────────
const companyData: Record<string, { url: string; logo?: string }> = {
  'Ontario Legal Tech':                      { url: 'https://ontariomandatorymediation.my.canva.site/ontario-court-helper' },
  "Queen's COMPSA":                          { url: 'https://compsa.ca/', logo: 'compsa' },
  'DoneMaker':                               { url: 'https://donemaker.com', logo: 'zivko' },
  'UWaterloo':                               { url: 'https://uwaterloo.ca', logo: 'uwaterloo' },
  'QueensU':                                 { url: 'http://queensu.ca/', logo: 'queenu' },
  'University of Toronto Engineering Outreach': { url: 'https://outreach.engineering.utoronto.ca', logo: 'uoft2' },
  'TypeScript':                              { url: 'https://www.typescriptlang.org' },
  'Next.js':                                 { url: 'https://nextjs.org' },
  'React':                                   { url: 'https://react.dev' },
  'Flask':                                   { url: 'https://flask.palletsprojects.com' },
  'FastAPI':                                 { url: 'https://fastapi.tiangolo.com' },
  'TailwindCSS':                             { url: 'https://tailwindcss.com' },
  'Figma':                                   { url: 'https://www.figma.com' },
  'Python':                                  { url: 'https://www.python.org' },
  'PyTorch':                                 { url: 'https://pytorch.org' },
  'NumPy':                                   { url: 'https://numpy.org' },
  'Pandas':                                  { url: 'https://pandas.pydata.org' },
  'Jupyter docs tool':                       { url: 'https://github.com/Elrich-Chen/jupyterlab_docs_helper' },
  'MongoDB':                                 { url: 'https://www.mongodb.com' },
  'JavaScript':                              { url: 'https://developer.mozilla.org/en-US/docs/Web/JavaScript' },
  'PostgreSQL':                              { url: 'https://www.postgresql.org' },
  'SQLAlchemy':                              { url: 'https://www.sqlalchemy.org' },
  'JWT':                                     { url: 'https://jwt.io' },
  'Stanford Code In Place':                  { url: 'https://codeinplace.stanford.edu', logo: 'stanford' },
  "Queen's Sports Analytics Organization":  { url: 'https://www.instagram.com/p/DH4J-30SmkA/?img_index=6', logo: 'qsao' },
  'Chinese Lion Dancing':                    { url: 'https://www.chinadailyhk.com/hk/article/603804' },
  'Tech Plus UW':                            { url: 'https://www.techplusuw.com', logo: 'techplusuw' },
  'UW FinTech':                              { url: 'https://www.instagram.com/uwfintech/?hl=en', logo: 'fintech' },
  'UW Data Science':                         { url: 'https://www.uwdatascience.ca/', logo: 'uw_dsc' },
};

const logoOverrides: Record<string, string> = {
  'uw_cube': 'cube',
  'uw cube': 'cube',
};

function resolveLogoFileName(logoName: string) {
  const cleaned = String(logoName).trim().toLowerCase();
  return logoOverrides[cleaned] ?? cleaned.replace(/\s+/g, '-');
}

function formatStatsAndCompanies(text: string) {
  const statPattern = /(\d+(?:\.\d+)?(?:st|nd|rd|th|[KMB%+]\+?))/gi;
  let result = text.replace(statPattern, '<strong><em>$1</em></strong>');

  result = result.replace(
    /\[LINK:\s*([^\]]+?)\s*\](.+?)\[\/LINK\]/gi,
    '<a href="$1" class="company-link" target="_blank" rel="noopener noreferrer"><strong><em>$2</em></strong></a>'
  );

  result = result.replace(/\[IMAGE:\s*([^\]|]+?)(?:\|([^\]]+))?\s*\]/gi, (_, fileName, link) => {
    const safeName = String(fileName).trim().replace(/^\/+/, '');
    const src = safeName.startsWith('http') ? safeName : `/photos/elrich_photos/${safeName}`;
    if (link) {
      const href = String(link).trim();
      return `<a href="${href}" class="highlight-preview-link" target="_blank" rel="noopener noreferrer"><img src="${src}" alt="Preview" loading="lazy" class="highlight-preview" /></a>`;
    }
    return `<img src="${src}" alt="Preview" loading="lazy" class="highlight-preview" />`;
  });

  result = result.replace(/\[LOGO:([^\]]+)\]/gi, (_, logoName) => {
    const fileName = resolveLogoFileName(String(logoName).trim());
    return `<img src="/logos/${fileName}.png" alt="${logoName}" width="20" height="20" loading="lazy" class="inline-block align-middle mx-1 logo-placeholder" onerror="this.style.display='none'" />`;
  });

  const companyKeys = Object.keys(companyData).sort((a, b) => b.length - a.length);
  const companyMap  = new Map(companyKeys.map((k) => [k.toLowerCase(), k]));
  const companyPattern = new RegExp(
    `(${companyKeys.map((k) => k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|')})`,
    'gi'
  );

  const tokens = result.split(/(<[^>]+>)/g);
  let insideAnchor = false;
  const rebuilt: string[] = [];

  for (const token of tokens) {
    if (/^<a\b/i.test(token))  { insideAnchor = true;  rebuilt.push(token); continue; }
    if (/^<\/a/i.test(token))  { insideAnchor = false; rebuilt.push(token); continue; }
    if (token.startsWith('<') || insideAnchor) { rebuilt.push(token); continue; }
    rebuilt.push(token.replace(companyPattern, (match) => {
      const key  = companyMap.get(match.toLowerCase());
      if (!key) return match;
      const data = companyData[key];
      return `<a href="${data.url}" target="_blank" rel="noopener" class="company-link"><strong><em>${match}</em></strong></a>`;
    }));
  }
  result = rebuilt.join('');
  result = result.replace(/View project\s*→/gi, '<a href="/projects" class="view-project-link">View project →</a>');
  return result;
}

// Contact links used in both connect sections
const contactLinks = [
  { href: 'mailto:elrichchen123@gmail.com', label: 'Email',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2zm0 2v.01L12 13l8-5.99V7H4z"/></svg>` },
  { href: 'https://github.com/Elrich-Chen', label: 'GitHub',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>` },
  { href: 'https://linkedin.com/in/elrichchen', label: 'LinkedIn',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 23.2 24 22.222 0h.003z"/></svg>` },
  { href: 'https://x.com/ChenElrich_', label: 'X',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>` },
  { href: 'https://drive.google.com/drive/folders/1JB5jWDtohn4ddSp5ro-jeZshZw2Q-5lc?usp=share_link', label: 'Resume',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15h8v2H8v-2zm0-4h8v2H8v-2zm0-4h5v2H8V7z"/></svg>` },
];
---

<Base title="Elrich Chen" description="CS @ UWaterloo | AI automations for DoneMaker | Aspiring Backend Engineer">

  <!-- Fixed basketball canvas — sits at z:15 for hero, drops to z:4 for content sections -->
  <Basketball />

  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section id="section-hero" class="scroll-section hero-section">
    <div class="hero-content">
      <h1 class="hero-name">Elrich Chen</h1>
      <p class="hero-tagline">CS @ UWaterloo &middot; Builder &middot; Engineer</p>
      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="hint-label">scroll</span>
        <span class="hint-arrow">↓</span>
      </div>
    </div>
  </section>

  <!-- ── RECENTLY I (LEFT) ──────────────────────────────────────────────────── -->
  {highlights?.data?.what_makes_me_different?.length > 0 && (
    <section id="section-recent" class="scroll-section">
      <div class="content-panel panel-left">
        <h2 class="panel-header">◆ Recently, I:</h2>
        <ul class="highlight-list">
          {highlights.data.what_makes_me_different.map((item: any) => {
            const mainPoint = typeof item === 'string' ? item : (item.point || '');
            const subPoints: string[] = typeof item === 'string' ? [] : (item.details || []);
            const parts = mainPoint.split(/\[LOGO:([^\]]+)\]/g);
            return (
              <li class="highlight-item-group">
                <div class="flex items-start">
                  <span class="bullet-point"></span>
                  <div class="flex-1">
                    <div class="highlight-main-point">
                      {parts.map((part: string, i: number) => {
                        if (i % 2 === 1) {
                          const n = resolveLogoFileName(part);
                          return <img src={`/logos/${n}.png`} alt={part} width="20" height="20" loading="lazy" class="inline-block align-middle mx-1 logo-placeholder" onerror={(e) => { (e.target as HTMLImageElement).style.display='none'; }} />;
                        }
                        return <span set:html={formatStatsAndCompanies(part)}></span>;
                      })}
                    </div>
                    {subPoints.length > 0 && (
                      <ul class="highlight-sub-points">
                        {subPoints.map((sub: string) => (
                          <li class="highlight-sub-item" set:html={formatStatsAndCompanies(sub)}></li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <!-- ── BUILDING (RIGHT) ──────────────────────────────────────────────────── -->
  {highlights?.data?.building?.length > 0 && (
    <section id="section-building" class="scroll-section">
      <div class="content-panel panel-right">
        <h2 class="panel-header">◆ Things I am working on:</h2>
        <ul class="highlight-list">
          {highlights.data.building.map((item: any) => {
            const mainPoint = typeof item === 'string' ? item : (item.point || '');
            let subPoints: string[] = typeof item === 'string' ? [] : (item.details || []);
            if (mainPoint.includes('TechPlus UW')) {
              subPoints = ["Organised mentorship & dinner for <strong><em>200+</em></strong> members for the F25 term.", ...subPoints];
            }
            const parts = mainPoint.split(/\[LOGO:([^\]]+)\]/g);
            return (
              <li class="highlight-item-group">
                <div class="flex items-start">
                  <span class="bullet-point"></span>
                  <div class="flex-1">
                    <div class="highlight-main-point">
                      {parts.map((part: string, i: number) => {
                        if (i % 2 === 1) {
                          const n = resolveLogoFileName(part);
                          return <img src={`/logos/${n}.png`} alt={part} width="20" height="20" loading="lazy" class="inline-block align-middle mx-1 logo-placeholder" onerror={(e) => { (e.target as HTMLImageElement).style.display='none'; }} />;
                        }
                        return <span set:html={formatStatsAndCompanies(part)}></span>;
                      })}
                    </div>
                    {subPoints.length > 0 && (
                      <ul class="highlight-sub-points">
                        {subPoints.map((sub: string) => (
                          <li class="highlight-sub-item" set:html={formatStatsAndCompanies(sub)}></li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <!-- ── LET'S CONNECT 1 (LEFT) ─────────────────────────────────────────────── -->
  <section id="section-connect1" class="scroll-section">
    <div class="content-panel panel-left contact-panel">
      <p class="contact-eyebrow">◆ Email</p>
      <h2 class="contact-heading">Let's connect.</h2>
      <p class="contact-body">
        Reach me directly at
        <a href="mailto:elrichchen123@gmail.com" class="contact-inline-link">elrichchen123@gmail.com</a>.
      </p>
      <a href="mailto:elrichchen123@gmail.com" class="contact-cta">Send an email</a>
      <div class="contact-icons">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            class="contact-icon"
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          >
            <span class="contact-icon-svg" set:html={link.icon}></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CLIENT REFERENCES (LEFT-ANCHORED HEADER + FULL-WIDTH CAROUSEL) ────── -->
  {testimonials.length > 0 && (
    <section id="section-clients" class="scroll-section clients-section">
      <div class="clients-inner">
        <div class="clients-header panel-left">
          <p class="clients-eyebrow">◆ Client References</p>
          <p class="clients-note">Highlights from early-stage startups I've partnered with.</p>
        </div>
        <div class="carousel-viewport" role="region" aria-label="Client testimonials carousel">
          <div class="carousel-track">
            <div class="carousel-group">
              {carouselItems.map((t) => (
                <div class="testimonial-card flip-card" data-flip-card>
                  <button class="flip-trigger" type="button" aria-pressed="false" aria-label="Flip testimonial"></button>
                  <div class="flip-inner">
                    <div class="flip-face flip-front">
                      <span class="flip-hint" aria-hidden="true">Flip to read</span>
                      <div class="testimonial-content">
                        <div class="preview-top">
                          <p class="preview-label">Tech stack</p>
                          <p class="preview-tech">{t.data.techStack?.join(' • ') ?? 'Tech stack inside'}</p>
                        </div>
                        <div class="preview-meta">
                          <span class="preview-person">{t.data.author}</span>
                          <span class="preview-company">{t.data.company}</span>
                        </div>
                        {t.data.project && <p class="preview-project">{t.data.project}</p>}
                      </div>
                    </div>
                    <div class="flip-face flip-back">
                      <span class="flip-hint" aria-hidden="true">Flip to close</span>
                      <div class="testimonial-content">
                        <p class="testimonial-text">"{t.data.text}"</p>
                        <div class="testimonial-author">
                          {t.data.companyLogo && (
                            <img src={`/logos/${t.data.companyLogo}.png`} alt={t.data.company}
                              class="company-logo" width="32" height="32" loading="lazy"
                              onerror={(e) => { (e.target as HTMLImageElement).style.display='none'; }} />
                          )}
                          <div class="author-details">
                            <div class="author-name">{t.data.author}</div>
                            <div class="author-title">{t.data.title}, {t.data.company}</div>
                            {t.data.project && <div class="author-project">{t.data.project}</div>}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="carousel-group" aria-hidden="true">
              {carouselItems.map((t) => (
                <div class="testimonial-card flip-card" data-flip-card>
                  <button class="flip-trigger" type="button" aria-pressed="false" aria-label="Flip testimonial"></button>
                  <div class="flip-inner">
                    <div class="flip-face flip-front">
                      <span class="flip-hint" aria-hidden="true">Flip to read</span>
                      <div class="testimonial-content">
                        <div class="preview-top">
                          <p class="preview-label">Tech stack</p>
                          <p class="preview-tech">{t.data.techStack?.join(' • ') ?? 'Tech stack inside'}</p>
                        </div>
                        <div class="preview-meta">
                          <span class="preview-person">{t.data.author}</span>
                          <span class="preview-company">{t.data.company}</span>
                        </div>
                        {t.data.project && <p class="preview-project">{t.data.project}</p>}
                      </div>
                    </div>
                    <div class="flip-face flip-back">
                      <span class="flip-hint" aria-hidden="true">Flip to close</span>
                      <div class="testimonial-content">
                        <p class="testimonial-text">"{t.data.text}"</p>
                        <div class="testimonial-author">
                          {t.data.companyLogo && (
                            <img src={`/logos/${t.data.companyLogo}.png`} alt={t.data.company}
                              class="company-logo" width="32" height="32" loading="lazy"
                              onerror={(e) => { (e.target as HTMLImageElement).style.display='none'; }} />
                          )}
                          <div class="author-details">
                            <div class="author-name">{t.data.author}</div>
                            <div class="author-title">{t.data.title}, {t.data.company}</div>
                            {t.data.project && <div class="author-project">{t.data.project}</div>}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── LET'S CONNECT 2 (RIGHT) ───────────────────────────────────────────── -->
  <section id="section-connect2" class="scroll-section">
    <div class="content-panel panel-right contact-panel">
      <p class="contact-eyebrow">◆ Get in touch</p>
      <h2 class="contact-heading">Work with me.</h2>
      <p class="contact-body">
        Open to internships, collaborations, and freelance projects.
      </p>
      <a href="mailto:elrichchen123@gmail.com" class="contact-cta">elrichchen123@gmail.com →</a>
      <div class="contact-icons">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            class="contact-icon"
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          >
            <span class="contact-icon-svg" set:html={link.icon}></span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Scroll sections: full-bleed, min 100vh ─────────────────────────────── */
  .scroll-section {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 4rem 0;
  }

  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .hero-section {
    justify-content: center;
    flex-direction: column;
    text-align: center;
    /* z-index intentionally NOT set — falls inside prose-measure z:10,
       which is below canvas z:15 during hero, so ball renders in front */
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    pointer-events: none;
    user-select: none;
  }

  .hero-name {
    font-size: clamp(3.5rem, 14vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    text-transform: uppercase;
    color: rgb(var(--fg));
    margin: 0;
  }

  .hero-tagline {
    font-size: clamp(0.8rem, 2vw, 1rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--muted));
    font-weight: 500;
    margin: 0;
  }

  .hero-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    margin-top: 2rem;
    opacity: 0.45;
  }

  .hint-label {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgb(var(--muted));
  }

  .hint-arrow {
    font-size: 1.2rem;
    color: rgb(var(--muted));
    animation: hint-bounce 1.8s ease-in-out infinite;
  }

  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-hint { animation: none; }
  }

  /* ── Content panels ────────────────────────────────────────────────────── */
  .content-panel {
    position: relative;
    z-index: 10; /* within prose-measure stacking context → always above canvas z:4 */
    max-width: min(460px, 90vw);
    padding: 2rem 1.75rem;
    background: rgba(var(--bg), 0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(var(--border), 0.14);
    border-radius: 18px;
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.08);
  }

  :global(html.dark) .content-panel {
    background: rgba(var(--bg), 0.9);
    border-color: rgba(var(--border), 0.2);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4);
  }

  /* Horizontal placement */
  .panel-left  { margin-left:  clamp(1.5rem, 7vw, 6rem); margin-right: auto; }
  .panel-right { margin-right: clamp(1.5rem, 7vw, 6rem); margin-left:  auto; }

  /* ── Panel headers ─────────────────────────────────────────────────────── */
  .panel-header {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--fg));
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(var(--border), 0.12);
  }

  /* ── Highlight lists (reuse global.css classes) ─────────────────────── */
  .highlight-list {
    list-style: none;
