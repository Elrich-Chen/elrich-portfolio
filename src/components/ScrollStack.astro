---
interface Props {
  itemDistance?:      number;   // gap (px) between cards in natural flow
  itemStackDistance?: number;   // vertical offset (px) between stacked tops
  stackPosition?:     string;   // distance from viewport top when stuck, e.g. '15%'
}

const {
  itemDistance      = 64,
  itemStackDistance = 16,
  stackPosition     = '15%',
} = Astro.props;
---

<div class="ss-container">
  <slot />
</div>

<!-- Sticky top value must be set after we know viewport height -->
<script define:vars={{ itemDistance, itemStackDistance, stackPosition }}>
  function applySticky() {
    const container = document.querySelector('.ss-container');
    if (!container) return;
    const cards = Array.from(container.querySelectorAll('.scroll-stack-card'));
    if (!cards.length) return;

    const viewH = window.innerHeight;
    const stackPx = typeof stackPosition === 'string' && stackPosition.includes('%')
      ? parseFloat(stackPosition) / 100 * viewH
      : parseFloat(stackPosition);

    const isIphone = window.matchMedia('(max-width: 480px)').matches;
    const isTablet = window.matchMedia('(max-width: 1024px)').matches;
    const navClearance = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-clearance')) || 96;
    const stackStep = isIphone ? 9 : isTablet ? 12 : itemStackDistance;
    const flowGap = isIphone ? 26 : isTablet ? 42 : itemDistance;
    const stickyTopBase = navClearance + (isIphone ? 6 : isTablet ? 10 : 14);
    const stickyTop = Math.max(stickyTopBase, stackPx);

    cards.forEach((card, i) => {
      card.style.top     = (stickyTop + i * stackStep) + 'px';
      card.style.zIndex  = String(i + 1);
      card.style.marginBottom = i < cards.length - 1 ? flowGap + 'px' : '0';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applySticky, { once: true });
  } else {
    applySticky();
  }
  window.addEventListener('resize', applySticky, { passive: true });
</script>

<style>
  .ss-container {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    padding-top:    1.75rem;
    padding-bottom: 50vh; /* keep last card pinned while reading */
    z-index: 5;
  }

  :global(.scroll-stack-card) {
    position: sticky;
    /* top is set via JS after we know viewport height */
    width: min(900px, 94vw);
    margin-left:  auto;
    margin-right: auto;
    padding: 3rem 3.5rem;
    border-radius: 24px;

    background: rgba(255, 255, 255, 0.60);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow:
      0 2px 12px rgba(0, 0, 0, 0.06),
      0 8px 36px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);

    box-sizing: border-box;

    /* Text contrast overrides */
    --muted: 40 40 40;
  }

  :global(html.dark .scroll-stack-card) {
    background: rgba(16, 14, 12, 0.70);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 2px 12px rgba(0, 0, 0, 0.45),
      0 8px 40px rgba(0, 0, 0, 0.50),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    --muted: 210 210 210;
  }

  @media (max-width: 1024px) {
    .ss-container {
      padding-top: 1.25rem;
      padding-bottom: 40vh;
    }

    :global(.scroll-stack-card) {
      width: min(900px, calc(100vw - 1.5rem));
      padding: 2.2rem 1.9rem;
      border-radius: 20px;
    }
  }

  @media (max-width: 480px) {
    .ss-container {
      padding-top: 1rem;
      padding-bottom: 32vh;
    }

    :global(.scroll-stack-card) {
      width: calc(100vw - 1rem);
      padding: 1.2rem 0.95rem 1.3rem;
      border-radius: 16px;
    }
  }
</style>
