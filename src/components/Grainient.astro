---
/**
 * Grainient — ported from React Bits.
 * WebGL2 animated gradient with film grain, ported to pure Astro + vanilla JS.
 * Uses the `ogl` library (Renderer, Program, Mesh, Triangle).
 *
 * Props are passed as data-* attributes so the script can import ogl normally.
 */
interface Props {
  color1?: string;
  color2?: string;
  color3?: string;
  color4?: string;
  color5?: string;
  darkColor1?: string;
  darkColor2?: string;
  darkColor3?: string;
  darkColor4?: string;
  darkColor5?: string;
  accentStrength?: number;
  timeSpeed?: number;
  colorBalance?: number;
  warpStrength?: number;
  warpFrequency?: number;
  warpSpeed?: number;
  warpAmplitude?: number;
  blendAngle?: number;
  blendSoftness?: number;
  rotationAmount?: number;
  noiseScale?: number;
  grainAmount?: number;
  grainScale?: number;
  grainAnimated?: boolean;
  contrast?: number;
  gamma?: number;
  saturation?: number;
  centerX?: number;
  centerY?: number;
  zoom?: number;
  class?: string;
}

const {
  color1          = '#718ab4',
  color2          = '#1d1a18',
  color3          = '#5b5b5b',
  color4          = '#c9a227',
  color5          = '#4a9e6b',
  darkColor1      = color1,
  darkColor2      = color2,
  darkColor3      = color3,
  darkColor4      = color4,
  darkColor5      = color5,
  accentStrength  = 0.38,
  timeSpeed       = 0.25,
  colorBalance  = 0.0,
  warpStrength  = 1.0,
  warpFrequency = 5.0,
  warpSpeed     = 2.0,
  warpAmplitude = 50.0,
  blendAngle    = 0.0,
  blendSoftness = 0.05,
  rotationAmount= 500.0,
  noiseScale    = 2.0,
  grainAmount   = 0.1,
  grainScale    = 2.0,
  grainAnimated = false,
  contrast      = 1.5,
  gamma         = 1.0,
  saturation    = 1.0,
  centerX       = 0.0,
  centerY       = 0.0,
  zoom          = 0.9,
  class: className = '',
} = Astro.props;
---

<div
  class:list={['grainient-root', className]}
  data-grainient
  data-color1={color1}
  data-color2={color2}
  data-color3={color3}
  data-color4={color4}
  data-color5={color5}
  data-dark-color1={darkColor1}
  data-dark-color2={darkColor2}
  data-dark-color3={darkColor3}
  data-dark-color4={darkColor4}
  data-dark-color5={darkColor5}
  data-accent-strength={accentStrength}
  data-time-speed={timeSpeed}
  data-color-balance={colorBalance}
  data-warp-strength={warpStrength}
  data-warp-frequency={warpFrequency}
  data-warp-speed={warpSpeed}
  data-warp-amplitude={warpAmplitude}
  data-blend-angle={blendAngle}
  data-blend-softness={blendSoftness}
  data-rotation-amount={rotationAmount}
  data-noise-scale={noiseScale}
  data-grain-amount={grainAmount}
  data-grain-scale={grainScale}
  data-grain-animated={grainAnimated ? '1' : '0'}
  data-contrast={contrast}
  data-gamma={gamma}
  data-saturation={saturation}
  data-center-x={centerX}
  data-center-y={centerY}
  data-zoom={zoom}
></div>

<style>
  .grainient-root {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .grainient-root canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
</style>

<script>
  import { Renderer, Program, Mesh, Triangle } from 'ogl';

  const VERTEX = /* glsl */ `#version 300 es
in vec2 position;
void main() {
  gl_Position = vec4(position, 0.0, 1.0);
}`;

  const FRAGMENT = /* glsl */ `#version 300 es
precision highp float;
uniform vec2  iResolution;
uniform float iTime;
uniform float uTimeSpeed;
uniform float uColorBalance;
uniform float uWarpStrength;
uniform float uWarpFrequency;
uniform float uWarpSpeed;
uniform float uWarpAmplitude;
uniform float uBlendAngle;
uniform float uBlendSoftness;
uniform float uRotationAmount;
uniform float uNoiseScale;
uniform float uGrainAmount;
uniform float uGrainScale;
uniform float uGrainAnimated;
uniform float uContrast;
uniform float uGamma;
uniform float uSaturation;
uniform vec2  uCenterOffset;
uniform float uZoom;
uniform vec3  uColor1;
uniform vec3  uColor2;
uniform vec3  uColor3;
uniform vec3  uColor4;
uniform vec3  uColor5;
uniform float uAccentStrength;
out vec4 fragColor;

#define S(a,b,t) smoothstep(a,b,t)
mat2 Rot(float a){float s=sin(a),c=cos(a);return mat2(c,-s,s,c);}
vec2 hash(vec2 p){p=vec2(dot(p,vec2(2127.1,81.17)),dot(p,vec2(1269.5,283.37)));return fract(sin(p)*43758.5453);}
float noise(vec2 p){vec2 i=floor(p),f=fract(p),u=f*f*(3.0-2.0*f);float n=mix(mix(dot(-1.0+2.0*hash(i+vec2(0,0)),f-vec2(0,0)),dot(-1.0+2.0*hash(i+vec2(1,0)),f-vec2(1,0)),u.x),mix(dot(-1.0+2.0*hash(i+vec2(0,1)),f-vec2(0,1)),dot(-1.0+2.0*hash(i+vec2(1,1)),f-vec2(1,1)),u.x),u.y);return 0.5+0.5*n;}

void mainImage(out vec4 o, vec2 C) {
  float t   = iTime * uTimeSpeed;
  vec2  uv  = C / iResolution.xy;
  float ratio = iResolution.x / iResolution.y;
  vec2  tuv = uv - 0.5 + uCenterOffset;
  tuv /= max(uZoom, 0.001);

  float degree = noise(vec2(t * 0.1, tuv.x * tuv.y) * uNoiseScale);
  tuv.y *= 1.0 / ratio;
  tuv *= Rot(radians((degree - 0.5) * uRotationAmount + 180.0));
  tuv.y *= ratio;

  float frequency  = uWarpFrequency;
  float ws         = max(uWarpStrength, 0.001);
  float amplitude  = uWarpAmplitude / ws;
  float warpTime   = t * uWarpSpeed;
  tuv.x += sin(tuv.y * frequency + warpTime) / amplitude;
  tuv.y += sin(tuv.x * (frequency * 1.5) + warpTime) / (amplitude * 0.5);

  vec3  colLav  = uColor1;
  vec3  colOrg  = uColor2;
  vec3  colDark = uColor3;
  vec3  colYel  = uColor4;
  vec3  colGrn  = uColor5;
  float b       = uColorBalance;
  float s       = max(uBlendSoftness, 0.0);
  mat2  blendRot = Rot(radians(uBlendAngle));
  float blendX  = (tuv * blendRot).x;
  float edge0   = -0.3 - b - s;
  float edge1   =  0.2 - b + s;
  float v0      =  0.5 - b + s;
  float v1      = -0.3 - b - s;
  vec3 layer1   = mix(colDark, colOrg, S(edge0, edge1, blendX));
  vec3 layer2   = mix(colOrg,  colLav, S(edge0, edge1, blendX));
  vec3 col      = mix(layer1, layer2, S(v0, v1, tuv.y));

  // Accent colors: noise-driven patches that drift independently
  float aN1 = noise(tuv * uNoiseScale * 1.8 + vec2(t * 0.06, t * 0.04));
  float aN2 = noise(tuv * uNoiseScale * 1.4 + vec2(-t * 0.05, t * 0.07) + vec2(3.7, 1.9));
  float accentMask1 = S(0.60, 0.80, aN1);          // yellow blob
  float accentMask2 = S(0.62, 0.82, aN2);          // green blob
  vec3  accent      = mix(colYel, colGrn, noise(tuv * 2.5 + t * 0.03));
  float accentBlend = clamp((accentMask1 + accentMask2) * 0.5, 0.0, 1.0) * uAccentStrength;
  col = mix(col, accent, accentBlend);

  vec2  grainUv = uv * max(uGrainScale, 0.001);
  if (uGrainAnimated > 0.5) { grainUv += vec2(iTime * 0.05); }
  float grain   = fract(sin(dot(grainUv, vec2(12.9898, 78.233))) * 43758.5453);
  col += (grain - 0.5) * uGrainAmount;

  col = (col - 0.5) * uContrast + 0.5;
  float luma = dot(col, vec3(0.2126, 0.7152, 0.0722));
  col = mix(vec3(luma), col, uSaturation);
  col = pow(max(col, 0.0), vec3(1.0 / max(uGamma, 0.001)));
  col = clamp(col, 0.0, 1.0);
  o   = vec4(col, 1.0);
}

void main() {
  vec4 o = vec4(0.0);
  mainImage(o, gl_FragCoord.xy);
  fragColor = o;
}`;

  function hexToRgb(hex: string): [number, number, number] {
    const r = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    if (!r) return [1, 1, 1];
    return [parseInt(r[1], 16) / 255, parseInt(r[2], 16) / 255, parseInt(r[3], 16) / 255];
  }

  function initGrainient(container: HTMLElement) {
    const d = container.dataset;

    const renderer = new Renderer({
      webgl: 2,
      alpha: false,
      antialias: false,
      dpr: Math.min(window.devicePixelRatio || 1, 2),
    });

    const gl     = renderer.gl;
    const canvas = gl.canvas as HTMLCanvasElement;
    canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;display:block;';
    container.appendChild(canvas);

    const geometry = new Triangle(gl);

    const isDark = () => document.documentElement.classList.contains('dark');

    const lightColors = {
      c1: hexToRgb(d.color1     ?? '#718ab4'),
      c2: hexToRgb(d.color2     ?? '#1d1a18'),
      c3: hexToRgb(d.color3     ?? '#5b5b5b'),
      c4: hexToRgb(d.color4     ?? '#c9a227'),
      c5: hexToRgb(d.color5     ?? '#4a9e6b'),
    };
    const darkColors = {
      c1: hexToRgb(d.darkColor1 ?? d.color1 ?? '#718ab4'),
      c2: hexToRgb(d.darkColor2 ?? d.color2 ?? '#1d1a18'),
      c3: hexToRgb(d.darkColor3 ?? d.color3 ?? '#5b5b5b'),
      c4: hexToRgb(d.darkColor4 ?? d.color4 ?? '#c9a227'),
      c5: hexToRgb(d.darkColor5 ?? d.color5 ?? '#4a9e6b'),
    };

    const activeColors = () => isDark() ? darkColors : lightColors;

    const program = new Program(gl, {
      vertex: VERTEX,
      fragment: FRAGMENT,
      uniforms: {
        iTime:           { value: 0 },
        iResolution:     { value: new Float32Array([1, 1]) },
        uTimeSpeed:      { value: parseFloat(d.timeSpeed      ?? '0.25') },
        uColorBalance:   { value: parseFloat(d.colorBalance   ?? '0') },
        uWarpStrength:   { value: parseFloat(d.warpStrength   ?? '1') },
        uWarpFrequency:  { value: parseFloat(d.warpFrequency  ?? '5') },
        uWarpSpeed:      { value: parseFloat(d.warpSpeed      ?? '2') },
        uWarpAmplitude:  { value: parseFloat(d.warpAmplitude  ?? '50') },
        uBlendAngle:     { value: parseFloat(d.blendAngle     ?? '0') },
        uBlendSoftness:  { value: parseFloat(d.blendSoftness  ?? '0.05') },
        uRotationAmount: { value: parseFloat(d.rotationAmount ?? '500') },
        uNoiseScale:     { value: parseFloat(d.noiseScale     ?? '2') },
        uGrainAmount:    { value: parseFloat(d.grainAmount    ?? '0.1') },
        uGrainScale:     { value: parseFloat(d.grainScale     ?? '2') },
        uGrainAnimated:  { value: parseFloat(d.grainAnimated  ?? '0') },
        uContrast:       { value: parseFloat(d.contrast       ?? '1.5') },
        uGamma:          { value: parseFloat(d.gamma          ?? '1') },
        uSaturation:     { value: parseFloat(d.saturation     ?? '1') },
        uCenterOffset:   { value: new Float32Array([parseFloat(d.centerX ?? '0'), parseFloat(d.centerY ?? '0')]) },
        uZoom:           { value: parseFloat(d.zoom           ?? '0.9') },
        uColor1:         { value: new Float32Array(activeColors().c1) },
        uColor2:         { value: new Float32Array(activeColors().c2) },
        uColor3:         { value: new Float32Array(activeColors().c3) },
        uColor4:         { value: new Float32Array(activeColors().c4) },
        uColor5:         { value: new Float32Array(activeColors().c5) },
        uAccentStrength: { value: parseFloat(d.accentStrength ?? '0.38') },
      },
    });

    // Swap uniforms whenever dark/light class changes on <html>
    const applyThemeColors = () => {
      const c = activeColors();
      (program.uniforms.uColor1.value as Float32Array).set(c.c1);
      (program.uniforms.uColor2.value as Float32Array).set(c.c2);
      (program.uniforms.uColor3.value as Float32Array).set(c.c3);
      (program.uniforms.uColor4.value as Float32Array).set(c.c4);
      (program.uniforms.uColor5.value as Float32Array).set(c.c5);
    };
    const themeObserver = new MutationObserver(applyThemeColors);
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    const mesh = new Mesh(gl, { geometry, program });

    const setSize = () => {
      const rect = container.getBoundingClientRect();
      const w = Math.max(1, Math.floor(rect.width));
      const h = Math.max(1, Math.floor(rect.height));
      renderer.setSize(w, h);
      const res = program.uniforms.iResolution.value as Float32Array;
      res[0] = gl.drawingBufferWidth;
      res[1] = gl.drawingBufferHeight;
    };

    const ro = new ResizeObserver(setSize);
    ro.observe(container);
    setSize();

    let rafId = 0;
    const t0  = performance.now();
    const loop = (t: number) => {
      program.uniforms.iTime.value = (t - t0) * 0.001;
      renderer.render({ scene: mesh });
      rafId = requestAnimationFrame(loop);
    };
    rafId = requestAnimationFrame(loop);

    // Cleanup on Astro page transitions
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      ro.disconnect();
      themeObserver.disconnect();
      try { container.removeChild(canvas); } catch {}
    }, { once: true });
  }

  document.querySelectorAll<HTMLElement>('[data-grainient]').forEach(initGrainient);
</script>
