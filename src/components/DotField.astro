---
interface Props {
  dotRadius?: number;
  dotSpacing?: number;
  cursorRadius?: number;
  cursorForce?: number;
  bulgeOnly?: boolean;
  bulgeStrength?: number;
  glowRadius?: number;
  sparkle?: boolean;
  waveAmplitude?: number;
  gradientFrom?: string;
  gradientTo?: string;
  glowColor?: string;
}

const {
  dotRadius    = 1.5,
  dotSpacing   = 14,
  cursorRadius = 500,
  cursorForce  = 0.1,
  bulgeOnly    = true,
  bulgeStrength = 67,
  glowRadius   = 160,
  sparkle      = false,
  waveAmplitude = 0,
  gradientFrom = 'rgba(168, 85, 247, 0.35)',
  gradientTo   = 'rgba(180, 151, 207, 0.25)',
  glowColor    = '#120F17',
} = Astro.props;

const glowId = `dfg-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class="dot-field-wrap"
  data-dot-radius={dotRadius}
  data-dot-spacing={dotSpacing}
  data-cursor-radius={cursorRadius}
  data-cursor-force={cursorForce}
  data-bulge-only={String(bulgeOnly)}
  data-bulge-strength={bulgeStrength}
  data-glow-radius={glowRadius}
  data-sparkle={String(sparkle)}
  data-wave-amplitude={waveAmplitude}
  data-gradient-from={gradientFrom}
  data-gradient-to={gradientTo}
  data-glow-color={glowColor}
  data-glow-id={glowId}
>
  <canvas class="dot-field-canvas" aria-hidden="true"></canvas>
  <svg class="dot-field-svg" aria-hidden="true">
    <defs>
      <radialGradient id={glowId}>
        <stop offset="0%"   stop-color={glowColor} />
        <stop offset="100%" stop-color="transparent" />
      </radialGradient>
    </defs>
    <circle
      class="dot-field-glow"
      cx="-9999" cy="-9999"
      r={glowRadius}
      fill={`url(#${glowId})`}
      style="opacity:0;will-change:opacity"
    />
  </svg>
</div>

<style>
  .dot-field-wrap {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .dot-field-canvas,
  .dot-field-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .dot-field-svg {
    pointer-events: none;
  }
</style>

<script>
  const TWO_PI = Math.PI * 2;

  const wrap   = document.querySelector('.dot-field-wrap') as HTMLElement;
  const canvas = wrap?.querySelector('.dot-field-canvas') as HTMLCanvasElement;
  const glowEl = wrap?.querySelector('.dot-field-glow') as SVGCircleElement;

  if (!wrap || !canvas) throw new Error('DotField: missing elements');

  const d = wrap.dataset;
  const cfg = {
    dotRadius:    parseFloat(d.dotRadius!),
    dotSpacing:   parseFloat(d.dotSpacing!),
    cursorRadius: parseFloat(d.cursorRadius!),
    cursorForce:  parseFloat(d.cursorForce!),
    bulgeOnly:    d.bulgeOnly === 'true',
    bulgeStrength: parseFloat(d.bulgeStrength!),
    sparkle:      d.sparkle === 'true',
    waveAmplitude: parseFloat(d.waveAmplitude!),
    gradientFrom: d.gradientFrom!,
    gradientTo:   d.gradientTo!,
  };

  const ctx = canvas.getContext('2d', { alpha: true })!;
  const dpr = Math.min(window.devicePixelRatio || 1, 2);

  type Dot = { ax: number; ay: number; sx: number; sy: number; vx: number; vy: number; x: number; y: number };
  let dots: Dot[] = [];
  let W = 0, H = 0;
  let resizeTimer: ReturnType<typeof setTimeout>;

  const mouse = { x: -9999, y: -9999, prevX: -9999, prevY: -9999, speed: 0 };
  let glowOpacity = 0;
  let engagement  = 0;
  let frameCount  = 0;

  function buildDots(w: number, h: number) {
    const step = cfg.dotRadius + cfg.dotSpacing;
    const cols = Math.floor(w / step);
    const rows = Math.floor(h / step);
    const padX = (w % step) / 2;
    const padY = (h % step) / 2;
    dots = new Array(rows * cols);
    let idx = 0;
    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const ax = padX + col * step + step / 2;
        const ay = padY + row * step + step / 2;
        dots[idx++] = { ax, ay, sx: ax, sy: ay, vx: 0, vy: 0, x: ax, y: ay };
      }
    }
  }

  function doResize() {
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width  = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width  = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    buildDots(W, H);
  }

  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(doResize, 100);
  }, { passive: true });

  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  }, { passive: true });

  setInterval(() => {
    const dx = mouse.prevX - mouse.x;
    const dy = mouse.prevY - mouse.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    mouse.speed += (dist - mouse.speed) * 0.5;
    if (mouse.speed < 0.001) mouse.speed = 0;
    mouse.prevX = mouse.x;
    mouse.prevY = mouse.y;
  }, 20);

  function tick() {
    frameCount++;
    const len = dots.length;
    const t   = frameCount * 0.02;

    const targetEng = Math.min(mouse.speed / 5, 1);
    engagement += (targetEng - engagement) * 0.06;
    if (engagement < 0.001) engagement = 0;

    glowOpacity += (engagement - glowOpacity) * 0.08;

    if (glowEl) {
      glowEl.setAttribute('cx', String(mouse.x));
      glowEl.setAttribute('cy', String(mouse.y));
      (glowEl as SVGCircleElement & { style: CSSStyleDeclaration }).style.opacity = String(glowOpacity);
    }

    ctx.clearRect(0, 0, W, H);

    const grad = ctx.createLinearGradient(0, 0, W, H);
    grad.addColorStop(0, cfg.gradientFrom);
    grad.addColorStop(1, cfg.gradientTo);
    ctx.fillStyle = grad;

    const cr   = cfg.cursorRadius;
    const crSq = cr * cr;
    const rad  = cfg.dotRadius / 2;
    const isBulge = cfg.bulgeOnly;

    ctx.beginPath();

    for (let i = 0; i < len; i++) {
      const dot = dots[i];
      const dx  = mouse.x - dot.ax;
      const dy  = mouse.y - dot.ay;
      const dSq = dx * dx + dy * dy;

      if (dSq < crSq && engagement > 0.01) {
        const dist  = Math.sqrt(dSq);
        if (isBulge) {
          const tt   = 1 - dist / cr;
          const push = tt * tt * cfg.bulgeStrength * engagement;
          const ang  = Math.atan2(dy, dx);
          dot.sx += (dot.ax - Math.cos(ang) * push - dot.sx) * 0.15;
          dot.sy += (dot.ay - Math.sin(ang) * push - dot.sy) * 0.15;
        } else {
          const ang  = Math.atan2(dy, dx);
          const move = (500 / dist) * (mouse.speed * cfg.cursorForce);
          dot.vx += Math.cos(ang) * -move;
          dot.vy += Math.sin(ang) * -move;
        }
      } else if (isBulge) {
        dot.sx += (dot.ax - dot.sx) * 0.1;
        dot.sy += (dot.ay - dot.sy) * 0.1;
      }

      if (!isBulge) {
        dot.vx *= 0.9;
        dot.vy *= 0.9;
        dot.x   = dot.ax + dot.vx;
        dot.y   = dot.ay + dot.vy;
        dot.sx += (dot.x - dot.sx) * 0.1;
        dot.sy += (dot.y - dot.sy) * 0.1;
      }

      let drawX = dot.sx;
      let drawY = dot.sy;
      if (cfg.waveAmplitude > 0) {
        drawY += Math.sin(dot.ax * 0.03 + t) * cfg.waveAmplitude;
        drawX += Math.cos(dot.ay * 0.03 + t * 0.7) * cfg.waveAmplitude * 0.5;
      }

      if (cfg.sparkle) {
        const hash = ((i * 2654435761) ^ (frameCount >> 3)) >>> 0;
        const r = (hash % 100) < 3 ? rad * 1.8 : rad;
        ctx.moveTo(drawX + r, drawY);
        ctx.arc(drawX, drawY, r, 0, TWO_PI);
      } else {
        ctx.moveTo(drawX + rad, drawY);
        ctx.arc(drawX, drawY, rad, 0, TWO_PI);
      }
    }

    ctx.fill();
    requestAnimationFrame(tick);
  }

  doResize();
  requestAnimationFrame(tick);
</script>
