---
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');

const navLinks = [
  { href: '/projects/', text: 'Projects' },
  { href: '/about/',    text: 'About'    },
  { href: '/photos/',   text: 'Photos'   },
  { href: '/hobbies/',  text: 'Hobbies'  },
];

const socialLinks = [
  { href: 'https://github.com/Elrich-Chen', text: 'GitHub' },
  { href: 'https://linkedin.com/in/elrichchen', text: 'LinkedIn' },
  { href: 'https://x.com/ChenElrich_', text: 'X' },
];
---

<!-- Fixed pill nav — z:100, single unified bar -->
<div class="pn-wrap">

  <!-- Single unified bar (desktop) -->
  <nav class="pn-bar pn-desktop" aria-label="Primary navigation">

    <!-- Brand -->
    <a href="/" class="pn-logo cursor-target" aria-label="Go to home">Elrich Chen</a>

    <span class="pn-sep" aria-hidden="true"></span>

    <!-- Nav links -->
    <ul class="pn-list" role="menubar">
      {navLinks.map((link) => (
        <li role="none">
          <a
            role="menuitem"
            href={link.href}
            class:list={['pn-pill', 'cursor-target', { 'pn-active': isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            <span class="pn-circle" aria-hidden="true"></span>
            <span class="pn-stack">
              <span class="pn-text">{link.text}</span>
              <span class="pn-text-hover" aria-hidden="true">{link.text}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <span class="pn-sep" aria-hidden="true"></span>

    <!-- Theme toggle -->
    <div class="pn-theme-wrap">
      <ThemeToggle />
    </div>

  </nav>

  <!-- Mobile: brand + hamburger -->
  <a href="/" class="pn-logo pn-mobile" aria-label="Go to home">Elrich Chen</a>
  <button
    class="pn-toggle pn-mobile"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="pn-mobile-panel"
  >
    <span class="pn-toggle-text-wrap" aria-hidden="true">
      <span class="pn-toggle-text-inner">
        <span class="pn-toggle-line">Menu</span>
        <span class="pn-toggle-line">Close</span>
      </span>
    </span>
    <span class="pn-toggle-icon" aria-hidden="true">
      <span class="pn-toggle-icon-line"></span>
      <span class="pn-toggle-icon-line pn-toggle-icon-line-v"></span>
    </span>
  </button>

</div>

<!-- Mobile staggered layers + panel -->
<div class="pn-mobile-prelayers pn-mobile" aria-hidden="true">
  <div class="pn-mobile-prelayer"></div>
  <div class="pn-mobile-prelayer"></div>
</div>
<aside id="pn-mobile-panel" class="pn-mobile-menu pn-mobile" aria-hidden="true">
  <div class="pn-mobile-inner">
    <ul class="pn-mobile-list" role="list">
      {navLinks.map((link) => (
        <li class="pn-mobile-item-wrap">
          <a
            href={link.href}
            class:list={['pn-mobile-link', { 'pn-active': isActive(link.href) }]}
          >
            <span class="pn-mobile-item-label">{link.text}</span>
          </a>
        </li>
      ))}
      <li class="pn-mobile-theme-row">
        <ThemeToggle />
      </li>
    </ul>
    <div class="pn-mobile-socials" aria-label="Social links">
      <h3 class="pn-mobile-socials-title">Socials</h3>
      <ul class="pn-mobile-social-list" role="list">
        {socialLinks.map((social) => (
          <li>
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="pn-mobile-social-link">
              {social.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>

<style>
  /* ── Fixed wrapper ──────────────────────────────────────────────────────── */
  .pn-wrap {
    position: fixed;
    top: var(--nav-top-offset);
    left: 50%;
    transform: translateX(-50%);
    z-index: var(--layer-nav);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    white-space: nowrap;
    pointer-events: auto;
    width: min(var(--page-max-width), calc(100vw - 2rem));
  }

  /* ── Single unified bar ─────────────────────────────────────────────────── */
  .pn-bar {
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 14px;
    gap: 6px;
    width: 100%;
    background: rgba(var(--bg), 0.84);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: none;
    border-radius: 9999px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  :global(html.dark) .pn-bar {
    box-shadow: 0 4px 24px rgba(0,0,0,0.35);
  }

  /* ── Brand text ─────────────────────────────────────────────────────────── */
  .pn-logo {
    display: inline-flex;
    align-items: center;
    padding: 0 20px;
    height: 100%;
    border-radius: 9999px;
    color: #fff;
    text-decoration: none;
    font-family: 'Reenie Beanie', cursive;
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }

  .pn-logo:hover { opacity: 0.7; }

  /* ── Separator ──────────────────────────────────────────────────────────── */
  .pn-sep {
    width: 1px;
    height: 22px;
    background: rgba(var(--border), 0.25);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ── Nav links list ─────────────────────────────────────────────────────── */
  .pn-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex: 1;
  }

  .pn-list > li {
    display: flex;
  }

  /* ── Individual pill link ───────────────────────────────────────────────── */
  .pn-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    height: 44px;         /* explicit: bar 52px − 2×4px padding */
    background: rgba(255, 255, 255, 0.72);
    color: rgb(var(--fg));
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    white-space: nowrap;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    line-height: 1;
    box-sizing: border-box;
  }

  /* fill circle */
  .pn-circle {
    position: absolute;
    left: 50%;
    bottom: 0;
    border-radius: 50%;
    background: rgb(var(--bg));
    z-index: 1;
    display: block;
    pointer-events: none;
    will-change: transform;
  }

  .pn-stack {
    position: relative;
    display: inline-block;
    line-height: 1;
    z-index: 2;
    overflow: hidden;
  }

  .pn-text {
    position: relative;
    z-index: 2;
    display: inline-block;
    line-height: 1;
    will-change: transform;
  }

  .pn-text-hover {
    position: absolute;
    left: 0;
    top: 0;
    color: rgb(var(--fg));
    z-index: 3;
    display: inline-block;
    will-change: transform, opacity;
  }

  .pn-pill.pn-active::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background: rgb(var(--bg));
    border-radius: 50%;
    z-index: 5;
  }

  /* active pill: always black, suppress hover fill */
  .pn-pill.pn-active {
    background: #0f172a !important;
    color: #ffffff !important;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.18), 0 0 0 1px rgba(15, 23, 42, 0.2);
  }

  :global(html.dark) .pn-pill {
    background: rgb(var(--fg));
    color: rgb(var(--bg));
  }

  .pn-pill.pn-active .pn-circle {
    display: none;
  }

  :global(html.light) .pn-pill.pn-active {
    background: #111827 !important;
    color: #ffffff !important;
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.26), 0 0 0 1px rgba(17, 24, 39, 0.28);
  }

  /* ── Theme toggle inside bar ────────────────────────────────────────────── */
  .pn-theme-wrap {
    width: 44px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pn-theme-wrap :global(.theme-toggle-btn) {
    background: transparent !important;
    width: 44px !important;
    height: 44px !important;
  }

  /* ── Mobile menu toggle ─────────────────────────────────────────────────── */
  .pn-toggle {
    height: var(--nav-height);
    min-width: 84px;
    background: rgba(var(--bg), 0.84);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0 1rem;
    flex-shrink: 0;
    color: rgb(var(--fg));
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    margin-left: auto;
    position: relative;
    z-index: calc(var(--layer-nav) + 1);
    border: 1px solid rgba(var(--border), 0.2);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.12);
  }

  .pn-toggle-text-wrap {
    height: 1em;
    overflow: hidden;
    display: inline-flex;
    align-items: flex-start;
  }

  .pn-toggle-text-inner {
    display: flex;
    flex-direction: column;
    line-height: 1;
    will-change: transform;
  }

  .pn-toggle-line {
    display: block;
    height: 1em;
    line-height: 1;
  }

  .pn-toggle-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
  }

  .pn-toggle-icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transform: translate(-50%, -50%);
  }

  .pn-toggle-icon-line-v {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .pn-toggle:focus-visible {
    outline: 2px solid rgba(var(--fg), 0.42);
    outline-offset: 3px;
  }

  /* ── Mobile staggered panel ─────────────────────────────────────────────── */
  .pn-mobile-prelayers {
    position: fixed;
    top: 0;
    right: 0;
    width: min(100vw, 420px);
    height: 100svh;
    z-index: calc(var(--layer-nav) - 3);
    pointer-events: none;
    visibility: hidden;
  }

  .pn-mobile-prelayer {
    position: absolute;
    inset: 0;
    transform: none;
    opacity: 1;
  }

  .pn-mobile-prelayer:first-child {
    background: #b497cf;
  }

  .pn-mobile-prelayer:last-child {
    background: #5227ff;
  }

  .pn-mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    width: min(100vw, 420px);
    height: 100svh;
    background: rgba(var(--bg), 0.96);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    z-index: calc(var(--layer-nav) - 2);
    visibility: hidden;
    transform: none;
    pointer-events: none;
    overflow-y: auto;
  }

  .pn-mobile-inner {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    padding: calc(var(--nav-top-offset) + var(--nav-height) + 1rem) 1.25rem 1.2rem;
    gap: 1.2rem;
  }

  .pn-mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    counter-reset: pn-mobile-item;
  }

  .pn-mobile-item-wrap {
    overflow: hidden;
  }

  .pn-mobile-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    color: rgb(var(--fg));
    text-decoration: none;
    font-size: clamp(1.7rem, 7.8vw, 2.7rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    padding-left: 0.59em;
    padding-right: 5.25em;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .pn-mobile-item-label {
    display: inline-block;
    transform-origin: 50% 100%;
    will-change: transform;
  }

  .pn-mobile-link::after {
    counter-increment: pn-mobile-item;
    content: counter(pn-mobile-item, decimal-leading-zero);
    position: absolute;
    right: 0.45em;
    top: 0.08em;
    font-size: 0.33em;
    font-weight: 500;
    letter-spacing: 0;
    color: #5227ff;
    opacity: 1;
  }

  .pn-mobile-link.pn-active {
    color: #111827;
  }

  .pn-mobile-theme-row {
    display: flex;
    justify-content: flex-start;
    margin-top: 0.35rem;
  }

  .pn-mobile-theme-row :global(.theme-toggle-btn) {
    width: 44px !important;
    height: 44px !important;
  }

  .pn-mobile-socials {
    margin-top: auto;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(var(--border), 0.14);
  }

  .pn-mobile-socials-title {
    margin: 0 0 0.55rem;
    font-size: 0.83rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5227ff;
  }

  .pn-mobile-social-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .pn-mobile-social-link {
    color: rgb(var(--fg));
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    padding-left: 0.85rem;
    opacity: 0.92;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .pn-mobile-social-link:hover,
  .pn-mobile-social-link:focus-visible {
    color: #5227ff;
    opacity: 1;
  }

  /* ── Responsive ─────────────────────────────────────────────────────────── */
  .pn-desktop { display: flex; }
  .pn-mobile  { display: none; }

  @media (max-width: 1024px) {
    .pn-wrap {
      width: min(var(--page-max-width), calc(100vw - 1.5rem));
      padding-inline: 0.35rem;
      box-sizing: border-box;
    }

    .pn-logo {
      padding: 0 16px;
      font-size: 1.35rem;
    }

    .pn-logo.pn-mobile {
      max-width: calc(100vw - 8.25rem);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .pn-pill {
      padding: 0 14px;
      font-size: 0.74rem;
      letter-spacing: 0.055em;
    }
  }

  @media (max-width: 1024px) {
    .pn-desktop { display: none !important; }
    .pn-mobile  { display: flex; }

    .pn-wrap {
      left: var(--nav-mobile-inline);
      right: var(--nav-mobile-inline);
      transform: none;
      justify-content: space-between;
      width: auto;
    }

    .pn-mobile-prelayers,
    .pn-mobile-menu {
      width: 100vw;
    }
  }

  @media (max-width: 480px) {
    .pn-wrap {
      padding-inline: 0.2rem;
    }

    .pn-toggle {
      min-width: 80px;
      padding: 0 0.9rem;
      font-size: 0.66rem;
    }

    .pn-logo.pn-mobile {
      max-width: calc(100vw - 7.7rem);
      padding: 0 12px;
      font-size: 1.2rem;
    }

    .pn-mobile-inner {
      padding: calc(var(--nav-top-offset) + var(--nav-height) + 0.8rem) 1rem 0.95rem;
    }

    .pn-mobile-link {
      font-size: clamp(1.45rem, 8vw, 2.15rem);
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const EASE = 'power3.out';
  let cleanupPillNav: (() => void) | undefined;

  function initPillNav() {
    cleanupPillNav?.();
    const cleanupFns: Array<() => void> = [];
    const listenerController = new AbortController();
    const { signal } = listenerController;

    /* ── Pill hover geometry + GSAP setup ────────────────────────────────── */
    function layoutPills() {
      document.querySelectorAll<HTMLElement>('.pn-pill').forEach(pill => {
        const circle = pill.querySelector<HTMLElement>('.pn-circle');
        if (!circle) return;

        const { width: w, height: h } = pill.getBoundingClientRect();
        if (w === 0 || h === 0) return;

        const R = ((w * w) / 4 + h * h) / (2 * h);
        const D = Math.ceil(2 * R) + 2;
        const delta = Math.ceil(R - Math.sqrt(Math.max(0, R * R - (w * w) / 4))) + 1;
        const originY = D - delta;

        circle.style.width = `${D}px`;
        circle.style.height = `${D}px`;
        circle.style.bottom = `-${delta}px`;

        gsap.set(circle, { xPercent: -50, scale: 0, transformOrigin: `50% ${originY}px` });

        const label = pill.querySelector<HTMLElement>('.pn-text');
        const hover = pill.querySelector<HTMLElement>('.pn-text-hover');
        if (label) gsap.set(label, { y: 0 });
        if (hover) gsap.set(hover, { y: h + 12, opacity: 0 });
      });
    }

    function attachPillListeners() {
      document.querySelectorAll<HTMLElement>('.pn-pill').forEach(pill => {
        if (pill.classList.contains('pn-active')) return; // keep active pill black

        pill.addEventListener('mouseenter', () => {
          const circle = pill.querySelector<HTMLElement>('.pn-circle');
          const label = pill.querySelector<HTMLElement>('.pn-text');
          const hover = pill.querySelector<HTMLElement>('.pn-text-hover');
          const h = pill.getBoundingClientRect().height;

          if (circle) gsap.to(circle, { scale: 1.2, xPercent: -50, duration: 0.3, ease: EASE, overwrite: 'auto' });
          if (label) gsap.to(label, { y: -(h + 8), duration: 0.3, ease: EASE, overwrite: 'auto' });
          if (hover) gsap.to(hover, { y: 0, opacity: 1, duration: 0.3, ease: EASE, overwrite: 'auto' });
        }, { signal });

        pill.addEventListener('mouseleave', () => {
          const circle = pill.querySelector<HTMLElement>('.pn-circle');
          const label = pill.querySelector<HTMLElement>('.pn-text');
          const hover = pill.querySelector<HTMLElement>('.pn-text-hover');
          const h = pill.getBoundingClientRect().height;

          if (circle) gsap.to(circle, { scale: 0, xPercent: -50, duration: 0.2, ease: EASE, overwrite: 'auto' });
          if (label) gsap.to(label, { y: 0, duration: 0.2, ease: EASE, overwrite: 'auto' });
          if (hover) gsap.to(hover, { y: h + 12, opacity: 0, duration: 0.2, ease: EASE, overwrite: 'auto' });
        }, { signal });
      });
    }

    /* ── Mobile staggered menu ───────────────────────────────────────────── */
    const toggleBtn = document.querySelector<HTMLButtonElement>('.pn-toggle');
    const mobileMenu = document.querySelector<HTMLElement>('.pn-mobile-menu');
    const preLayersWrap = document.querySelector<HTMLElement>('.pn-mobile-prelayers');
    const preLayers = Array.from(document.querySelectorAll<HTMLElement>('.pn-mobile-prelayer'));
    const toggleTextInner = document.querySelector<HTMLElement>('.pn-toggle-text-inner');
    const toggleIcon = document.querySelector<HTMLElement>('.pn-toggle-icon');
    const mobileItemLabels = Array.from(document.querySelectorAll<HTMLElement>('.pn-mobile-item-label'));
    const mobileItemLinks = Array.from(document.querySelectorAll<HTMLElement>('.pn-mobile-link'));
    const socialsTitle = document.querySelector<HTMLElement>('.pn-mobile-socials-title');
    const socialLinkEls = Array.from(document.querySelectorAll<HTMLElement>('.pn-mobile-social-link'));
    const menuOffscreen = 100;
    let isOpen = false;
    let openTimeline: gsap.core.Timeline | null = null;
    let closeTween: gsap.core.Tween | null = null;

    function prepMobileStates() {
      if (!mobileMenu || !toggleTextInner || !toggleIcon) return;
      gsap.set(mobileMenu, { xPercent: menuOffscreen, opacity: 1 });
      gsap.set(preLayers, { xPercent: menuOffscreen, opacity: 1 });
      gsap.set(toggleTextInner, { yPercent: 0 });
      gsap.set(toggleIcon, { rotate: 0, transformOrigin: '50% 50%' });
      if (mobileItemLabels.length) gsap.set(mobileItemLabels, { yPercent: 140, rotate: 10 });
      if (socialsTitle) gsap.set(socialsTitle, { opacity: 0 });
      if (socialLinkEls.length) gsap.set(socialLinkEls, { y: 20, opacity: 0 });
    }

    function animateToggleState(opening: boolean) {
      if (!toggleTextInner || !toggleIcon) return;
      gsap.to(toggleIcon, { rotate: opening ? 225 : 0, duration: opening ? 0.7 : 0.3, ease: EASE, overwrite: 'auto' });
      gsap.to(toggleTextInner, { yPercent: opening ? -50 : 0, duration: 0.35, ease: EASE, overwrite: 'auto' });
      if (toggleBtn) toggleBtn.setAttribute('aria-label', opening ? 'Close menu' : 'Open menu');
    }

    function closeMobile() {
      if (!toggleBtn || !mobileMenu) return;
      isOpen = false;
      toggleBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      animateToggleState(false);
      openTimeline?.kill();
      openTimeline = null;
      closeTween?.kill();
      closeTween = gsap.to([...preLayers, mobileMenu], {
        xPercent: menuOffscreen,
        duration: 0.3,
        ease: 'power3.in',
        overwrite: 'auto',
        onComplete: () => {
          gsap.set(mobileMenu, { visibility: 'hidden', pointerEvents: 'none' });
          if (preLayersWrap) gsap.set(preLayersWrap, { visibility: 'hidden' });
          prepMobileStates();
        },
      });
    }

    if (toggleBtn && mobileMenu) {
      prepMobileStates();
      let ignoreClickUntil = 0;
      let ignoreDocCloseUntil = 0;
      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent || '');
      const handleToggle = (event?: Event) => {
        event?.preventDefault();
        event?.stopPropagation?.();
        isOpen = !isOpen;
        toggleBtn.setAttribute('aria-expanded', String(isOpen));
        mobileMenu.setAttribute('aria-hidden', String(!isOpen));

        if (isOpen) {
          animateToggleState(true);
          if (preLayersWrap) gsap.set(preLayersWrap, { visibility: 'visible' });
          gsap.set(mobileMenu, { visibility: 'visible', pointerEvents: 'auto' });
          prepMobileStates();
          openTimeline?.kill();
          closeTween?.kill();
          openTimeline = gsap.timeline();
          preLayers.forEach((layer, index) => {
            openTimeline?.to(layer, {
              xPercent: 0,
              duration: 0.5,
              ease: 'power4.out',
            }, index * 0.07);
          });
          openTimeline.to(mobileMenu, {
            xPercent: 0,
            duration: 0.62,
            ease: 'power4.out',
          }, preLayers.length ? (preLayers.length - 1) * 0.07 + 0.08 : 0);
          if (mobileItemLabels.length) {
            openTimeline.to(mobileItemLabels, {
              yPercent: 0,
              rotate: 0,
              duration: 0.9,
              ease: 'power4.out',
              stagger: 0.09,
            }, '>-0.45');
          }
          if (socialsTitle) {
            openTimeline.to(socialsTitle, { opacity: 1, duration: 0.4, ease: 'power2.out' }, '>-0.2');
          }
          if (socialLinkEls.length) {
            openTimeline.to(socialLinkEls, {
              y: 0,
              opacity: 1,
              duration: 0.45,
              ease: 'power3.out',
              stagger: 0.07,
            }, '<+0.04');
          }
        } else {
          closeMobile();
        }
      };

      const handleClick = (event: MouseEvent) => {
        if (Date.now() < ignoreClickUntil) return;
        handleToggle(event);
      };

      const handleTouchEnd = (event: TouchEvent) => {
        // On iOS, `touchend` can be followed by a synthetic `click`.
        // Prevent double-toggling so the menu reliably stays open.
        ignoreClickUntil = Date.now() + 500;
        ignoreDocCloseUntil = Date.now() + 1200;
        handleToggle(event);
      };

      toggleBtn.addEventListener('click', handleClick, { signal });
      toggleBtn.addEventListener('touchend', handleTouchEnd, { signal, passive: false });

      if (!isIOS) {
        document.addEventListener('click', (e) => {
          if (Date.now() < ignoreDocCloseUntil) return;
          if (
            isOpen &&
            !toggleBtn.contains(e.target as Node) &&
            !preLayersWrap?.contains(e.target as Node) &&
            !mobileMenu.contains(e.target as Node)
          ) {
            closeMobile();
          }
        }, { signal });
      }

      mobileMenu.querySelectorAll<HTMLAnchorElement>('a').forEach(link => {
        link.addEventListener('click', () => {
          if (link.classList.contains('pn-mobile-social-link')) return;
          closeMobile();
        }, { signal });
      });
    }

    /* ── Resize ──────────────────────────────────────────────────────────── */
    let resizeTimer: ReturnType<typeof setTimeout> | undefined;
    window.addEventListener('resize', () => {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(layoutPills, 100);
    }, { passive: true, signal });
    cleanupFns.push(() => {
      if (resizeTimer) clearTimeout(resizeTimer);
    });

    /* ── Init ────────────────────────────────────────────────────────────── */
    if (document.fonts?.ready) {
      document.fonts.ready.then(layoutPills).catch(layoutPills);
    } else {
      layoutPills();
    }
    attachPillListeners();

    cleanupPillNav = () => {
      listenerController.abort();
      cleanupFns.forEach((runCleanup) => runCleanup());
      cleanupFns.length = 0;
      cleanupPillNav = undefined;
    };
  }

  initPillNav();
  document.addEventListener('astro:before-swap', () => cleanupPillNav?.(), { once: true });
</script>
