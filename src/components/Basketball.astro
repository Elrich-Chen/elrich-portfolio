---
// Basketball.astro
// Full-viewport fixed canvas — overlays entire page, pointer-events:none.
// The ball position is driven by GSAP ScrollTrigger listening to section IDs
// in the parent page. Canvas uses alpha:true so page background shows through.
//
// Three.js WebGLRenderer: https://threejs.org/docs/#api/en/renderers/WebGLRenderer
// GLTFLoader (r150+): https://threejs.org/docs/#examples/en/loaders/GLTFLoader
// GSAP ScrollTrigger: https://gsap.com/docs/v3/Plugins/ScrollTrigger/
---

<!-- Fixed canvas — sits above page background (z:5), below content panels (z:10) -->
<canvas id="bball-canvas" class="bball-canvas-fixed" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Section IDs and the Three.js scene position the ball moves TO when that
  // section enters the viewport. x/y are in Three.js scene units (camera z=5).
  const SCENES = [
    { id: 'section-hero',     x: 0,    y: 0    }, // center
    { id: 'section-recent',   x: 2.4,  y: 1.1  }, // top-right
    { id: 'section-building', x: -2.4, y: -1.1 }, // bottom-left
    { id: 'section-connect1', x: 2.4,  y: 1.1  }, // top-right
    { id: 'section-clients',  x: 2.4,  y: -1.1 }, // bottom-right
    { id: 'section-connect2', x: -2.4, y: 1.1  }, // top-left
  ];

  function initBasketball() {
    const canvas = document.getElementById('bball-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // --- Renderer ---
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    // --- Scene + Camera ---
    const scene = new THREE.Scene();
    let W = window.innerWidth;
    let H = window.innerHeight;
    const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
    camera.position.set(0, 0, 5);
    renderer.setSize(W, H, false);

    // --- Lighting (boosted for high visibility) ---
    const ambient = new THREE.AmbientLight(0xffffff, 1.0);
    scene.add(ambient);

    const keyLight = new THREE.DirectionalLight(0xffffff, 3.5);
    keyLight.position.set(5, 8, 5);
    scene.add(keyLight);

    // Top spotlight for sharp highlight on the ball
    const topLight = new THREE.PointLight(0xffffff, 2.0, 20);
    topLight.position.set(0, 6, 3);
    scene.add(topLight);

    const fillLight = new THREE.DirectionalLight(0xffa060, 1.0);
    fillLight.position.set(-4, -2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0x6080ff, 0.8);
    rimLight.position.set(0, 0, -6);
    scene.add(rimLight);

    // --- State ---
    let mesh: THREE.Object3D | null = null;
    let spinAngle = 0;
    let scrollVelocity = 0;

    // Proxy object — GSAP animates this; rAF reads it and applies to mesh.
    // This prevents GSAP/requestAnimationFrame conflicts on the same property.
    const pos = { x: 0, bobY: 0, targetY: 0, z_rot: 0 };

    // --- Load GLB ---
    const loader = new GLTFLoader();
    loader.load(
      '/3D-MODELS/BasketBall.glb',
      (gltf) => {
        mesh = gltf.scene;

        // Center model at origin using its bounding box
        const box = new THREE.Box3().setFromObject(mesh);
        const center = box.getCenter(new THREE.Vector3());
        const size   = box.getSize(new THREE.Vector3());
        mesh.position.sub(center);

        // Scale so longest axis = 1.8 scene units
        const maxDim = Math.max(size.x, size.y, size.z);
        mesh.scale.setScalar(1.8 / maxDim);

        scene.add(mesh);

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return; // ball renders statically at center

        // --- Vertical bob (independent of scroll) ---
        gsap.to(pos, {
          bobY: 0.2,
          duration: 1.8,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
        });

        // --- Diagonal per-section ScrollTriggers ---
        // Each consecutive pair of SCENES creates a scrubbed transition.
        SCENES.forEach((sceneEntry, i) => {
          if (i === 0) return; // hero is the starting position, no trigger needed
          const prev = SCENES[i - 1];
          const el = document.getElementById(sceneEntry.id);
          if (!el) return;

          ScrollTrigger.create({
            trigger: el,
            start: 'top 85%',
            end:   'top 15%',
            scrub: 1.5,
            onUpdate(self) {
              pos.x       = gsap.utils.interpolate(prev.x, sceneEntry.x, self.progress);
              pos.targetY = gsap.utils.interpolate(prev.y, sceneEntry.y, self.progress);
              pos.z_rot   = gsap.utils.interpolate(
                prev.x > sceneEntry.x ? -0.2 : 0.2,
                sceneEntry.x > prev.x ? -0.2 : 0.2,
                self.progress
              );

              // Boost spin on fast scroll
              const v = Math.abs(self.getVelocity());
              scrollVelocity = Math.min(v / 600, 3.0);
            },
          });

          // Snap the position target cleanly once section fully entered
          ScrollTrigger.create({
            trigger: el,
            start: 'top 15%',
            end:   'bottom bottom',
            onEnter() {
              gsap.to(pos, { x: sceneEntry.x, targetY: sceneEntry.y, z_rot: sceneEntry.x > 0 ? -0.2 : 0.2, duration: 0.4, ease: 'power2.out' });
            },
            onLeaveBack() {
              gsap.to(pos, { x: prev.x, targetY: prev.y, z_rot: prev.x > 0 ? -0.2 : 0.2, duration: 0.4, ease: 'power2.out' });
            },
          });
        });
      },
      undefined,
      (err) => console.error('[Basketball] GLTFLoader error:', err)
    );

    // --- z-index toggle: high (15) on hero so ball renders IN FRONT of hero text;
    //     low (4) for content sections so panels render in front of ball.
    //     prose-measure in Base.astro has z-index:10, so:
    //       canvas z:15 → above prose-measure → ball covers hero text  ✓
    //       canvas z:4  → below prose-measure → content panels cover ball ✓
    const heroEl = document.getElementById('section-hero');
    if (heroEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      ScrollTrigger.create({
        trigger: heroEl,
        start: 'bottom 70%',
        onEnter()     { canvas.style.zIndex = '4';  },
        onLeaveBack() { canvas.style.zIndex = '15'; },
      });
    }

    // --- Resize handler ---
    function onResize() {
      W = window.innerWidth;
      H = window.innerHeight;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H, false);
    }
    window.addEventListener('resize', onResize, { passive: true });

    // --- Animation loop ---
    function animate() {
      requestAnimationFrame(animate);
      if (mesh) {
        spinAngle       += 0.008 + scrollVelocity * 0.025;
        scrollVelocity  *= 0.92; // dampen each frame

        mesh.rotation.y  = spinAngle;   // rAF owns Y rotation
        mesh.rotation.z  = pos.z_rot;   // tilt from GSAP
        mesh.position.x  = pos.x;       // x from GSAP section triggers
        mesh.position.y  = pos.targetY + pos.bobY;
      }
      renderer.render(scene, camera);
    }
    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBasketball, { once: true });
  } else {
    initBasketball();
  }
</script>

<style>
  .bball-canvas-fixed {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none; /* click-through — page content remains interactive */
    z-index: 15;          /* starts above prose-measure (z:10) for hero overlay;
                             toggled to z:4 by GSAP once hero section exits */
    display: block;
  }
</style>
