---
// Basketball.astro
// Full-viewport fixed WebGL canvas. The ball stays on screen at all times.
// GSAP ScrollTrigger reads section IDs from the home page and moves the ball
// diagonally between them as the user scrolls.
//
// Three.js WebGLRenderer: https://threejs.org/docs/#api/en/renderers/WebGLRenderer
// GLTFLoader: https://threejs.org/docs/#examples/en/loaders/GLTFLoader
// GSAP ScrollTrigger: https://gsap.com/docs/v3/Plugins/ScrollTrigger/
---

<!-- Fixed full-viewport canvas — pointer-events:none so content stays clickable -->
<canvas id="bball-canvas" class="bball-canvas" aria-label="Basketball 3D animation" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Scene positions (Three.js units) for each home page section.
  // x: horizontal (positive = right), y: vertical (positive = up)
  const SCENES: Record<string, { x: number; y: number }> = {
    'section-hero':     { x:  0,    y:  0    },
    'section-recent':   { x:  2.4,  y:  1.1  }, // top-right
    'section-building': { x: -2.4,  y: -1.1  }, // bottom-left
    'section-connect1': { x:  2.4,  y:  1.1  }, // top-right
    'section-clients':  { x:  2.4,  y: -1.1  }, // bottom-right
    'section-connect2': { x: -2.4,  y:  1.1  }, // top-left
  };

  const SECTION_ORDER = [
    'section-hero',
    'section-recent',
    'section-building',
    'section-connect1',
    'section-clients',
    'section-connect2',
  ];

  function initBasketball() {
    const canvas = document.getElementById('bball-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // Renderer — alpha:true keeps background transparent
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    // Scene + Camera
    const scene = new THREE.Scene();
    let W = window.innerWidth;
    let H = window.innerHeight;
    const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
    camera.position.set(0, 0, 5);
    renderer.setSize(W, H, false);

    // ── Lighting (boosted) ─────────────────────────────────────────────────
    // Ambient: fills shadows so ball isn't dark on any side
    const ambient = new THREE.AmbientLight(0xffffff, 1.0);
    scene.add(ambient);

    // Key light: primary source from upper-right front
    const keyLight = new THREE.DirectionalLight(0xffffff, 3.5);
    keyLight.position.set(5, 8, 5);
    keyLight.castShadow = true;
    scene.add(keyLight);

    // Top spotlight: adds a bright highlight crown on the ball
    const topLight = new THREE.PointLight(0xffffff, 2.0, 20);
    topLight.position.set(0, 6, 3);
    scene.add(topLight);

    // Fill light: warm orange bounce from below-left
    const fillLight = new THREE.DirectionalLight(0xffa060, 1.0);
    fillLight.position.set(-4, -2, 3);
    scene.add(fillLight);

    // Rim light: cool blue backlight for depth
    const rimLight = new THREE.DirectionalLight(0x6080ff, 0.8);
    rimLight.position.set(0, 0, -6);
    scene.add(rimLight);
    // ──────────────────────────────────────────────────────────────────────

    // Position proxy — GSAP animates this, rAF applies it to mesh
    const pos = { x: 0, y: 0, z_rot: 0 };

    let mesh: THREE.Object3D | null = null;
    let spinAngle = 0;
    let scrollVelocity = 0;

    // Load GLB model
    const loader = new GLTFLoader();
    loader.load(
      '/3D-MODELS/BasketBall.glb',
      (gltf) => {
        mesh = gltf.scene;

        // Center model at origin + scale to ~1.8 units
        const box = new THREE.Box3().setFromObject(mesh);
        const center = box.getCenter(new THREE.Vector3());
        const size   = box.getSize(new THREE.Vector3());
        mesh.position.sub(center);
        mesh.scale.setScalar(1.8 / Math.max(size.x, size.y, size.z));

        scene.add(mesh);

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;

        // ── Vertical bob (scroll-independent) ─────────────────────────────
        gsap.to(pos, {
          y: 0.18,
          duration: 1.8,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
        });

        // ── Per-section diagonal transitions ───────────────────────────────
        // For each consecutive section pair, create a scrubbing ScrollTrigger
        // that interpolates the ball from the previous position to the next.
        SECTION_ORDER.forEach((sectionId, i) => {
          if (i === 0) return; // hero is the starting position

          const prev = SCENES[SECTION_ORDER[i - 1]];
          const next = SCENES[sectionId];

          const el = document.getElementById(sectionId);
          if (!el) return;

          ScrollTrigger.create({
            trigger: el,
            start: 'top 85%',
            end: 'top 15%',
            scrub: 1.5,
            onUpdate(self) {
              pos.x    = gsap.utils.interpolate(prev.x, next.x, self.progress);
              // bob offset preserved — only override the base y, not the bobbing delta
              // We store the "target base y" separately and let the bob tween add on top
              pos.z_rot = gsap.utils.interpolate(
                prev.x > 0 ? -0.25 : prev.x < 0 ? 0.25 : 0,
                next.x > 0 ? -0.25 : next.x < 0 ? 0.25 : 0,
                self.progress
              );
              // Boost spin on scroll
              const v = Math.abs(self.getVelocity());
              scrollVelocity = Math.min(v / 800, 3.0);
            },
          });
        });

        // Separate y-position timeline for vertical diagonal movement
        // (keeps separate from the bob tween which uses pos.y as a delta)
        const baseY = { v: 0 };
        SECTION_ORDER.forEach((sectionId, i) => {
          if (i === 0) return;
          const prev = SCENES[SECTION_ORDER[i - 1]];
          const next = SCENES[sectionId];
          const el = document.getElementById(sectionId);
          if (!el) return;

          ScrollTrigger.create({
            trigger: el,
            start: 'top 85%',
            end: 'top 15%',
            scrub: 1.5,
            onUpdate(self) {
              baseY.v = gsap.utils.interpolate(prev.y, next.y, self.progress);
            },
          });
        });

        // rAF applies both baseY + bob (pos.y) to mesh
        (window as any).__bball_baseY = baseY;
      },
      undefined,
      (err) => console.error('Basketball GLTFLoader error:', err)
    );

    // Resize handler
    function onResize() {
      W = window.innerWidth;
      H = window.innerHeight;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H, false);
    }
    window.addEventListener('resize', onResize, { passive: true });

    // Animation loop
    function animate() {
      requestAnimationFrame(animate);
      if (mesh) {
        spinAngle += 0.008 + scrollVelocity * 0.025;
        scrollVelocity *= 0.92;

        const baseY = (window as any).__bball_baseY?.v ?? 0;

        mesh.rotation.y = spinAngle;
        mesh.rotation.z = pos.z_rot;
        mesh.position.x = pos.x;
        mesh.position.y = baseY + pos.y; // base diagonal Y + bob delta
      }
      renderer.render(scene, camera);
    }
    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBasketball, { once: true });
  } else {
    initBasketball();
  }
</script>

<style>
  .bball-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none; /* content remains fully interactive */
    z-index: 5;
    display: block;
  }
</style>
