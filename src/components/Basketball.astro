---
// Basketball.astro
// Phase 1 (hero): ball centered, full size.
// Phase 2 (post-hero): ball shrinks and flies to top-right corner, stays there.
---

<canvas id="bball-canvas" class="bball-canvas-fixed" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initBasketball() {
    const canvas = document.getElementById('bball-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // --- Renderer ---
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // --- Scene + Camera ---
    const scene = new THREE.Scene();
    let W = window.innerWidth;
    let H = window.innerHeight;
    const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
    camera.position.set(0, 0, 5);
    renderer.setSize(W, H, false);

    // --- Lighting ---
    scene.add(new THREE.AmbientLight(0xffffff, 1.8));

    const keyLight = new THREE.DirectionalLight(0xffffff, 5.5);
    keyLight.position.set(5, 8, 5);
    scene.add(keyLight);

    const topLight = new THREE.PointLight(0xffffff, 3.5, 20);
    topLight.position.set(0, 6, 3);
    scene.add(topLight);

    const fillLight = new THREE.DirectionalLight(0xffa060, 1.4);
    fillLight.position.set(-4, -2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0x6080ff, 1.2);
    rimLight.position.set(0, 0, -6);
    scene.add(rimLight);

    // --- Proxy object (GSAP writes, rAF reads) ---
    const pos = { x: 0, targetY: 0, bobY: 0, scale: 1.0, z_rot: 0 };

    // --- Compute world-space top-right corner at z=0 ---
    function getCornerPos() {
      const fovRad = (45 * Math.PI) / 180;
      const halfH  = Math.tan(fovRad / 2) * 5; // camera z = 5
      const halfW  = halfH * (W / H);
      return { x: halfW * 0.74, y: halfH * 0.70 };
    }

    // --- State ---
    let mesh: THREE.Object3D | null = null;
    let baseScale = 1;
    let spinAngle  = 0;
    let scrollVelocity = 0;

    // --- Load GLB ---
    const loader = new GLTFLoader();
    loader.load(
      '/3D-MODELS/BasketBall.glb',
      (gltf) => {
        mesh = gltf.scene;

        const box    = new THREE.Box3().setFromObject(mesh);
        const center = box.getCenter(new THREE.Vector3());
        const size   = box.getSize(new THREE.Vector3());
        mesh.position.sub(center);

        const maxDim = Math.max(size.x, size.y, size.z);
        baseScale    = 1.8 / maxDim;
        mesh.scale.setScalar(baseScale);
        scene.add(mesh);

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        // Gentle idle bob
        gsap.to(pos, {
          bobY: 0.18,
          duration: 1.8,
          ease: 'sine.inOut',
          yoyo: true,
          repeat: -1,
        });

        // --- Hero exit: ball shrinks & flies to top-right ---
        const heroEl = document.getElementById('section-hero');
        if (!heroEl) return;

        ScrollTrigger.create({
          trigger: heroEl,
          start: 'bottom 75%',
          end:   'bottom 15%',
          scrub: 1.4,
          onUpdate(self) {
            const corner = getCornerPos();
            pos.x       = gsap.utils.interpolate(0,          corner.x, self.progress);
            pos.targetY = gsap.utils.interpolate(0,          corner.y, self.progress);
            pos.scale   = gsap.utils.interpolate(1.0,        0.2,      self.progress);
            pos.z_rot   = gsap.utils.interpolate(0,          0.25,     self.progress);
            scrollVelocity = Math.min(Math.abs(self.getVelocity()) / 600, 2.5);
          },
          onLeave() {
            // Snap to corner if user scrolls very fast
            const corner = getCornerPos();
            gsap.to(pos, { x: corner.x, targetY: corner.y, scale: 0.2, duration: 0.35, ease: 'power2.out' });
          },
          onEnterBack() {
            // Restore to center when scrolling back to top
            gsap.to(pos, { x: 0, targetY: 0, scale: 1.0, z_rot: 0, duration: 0.45, ease: 'power2.out' });
          },
        });
      },
      undefined,
      (err) => console.error('[Basketball] GLTFLoader error:', err)
    );

    // --- Resize ---
    function onResize() {
      W = window.innerWidth;
      H = window.innerHeight;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H, false);
    }
    window.addEventListener('resize', onResize, { passive: true });

    // --- Animation loop ---
    function animate() {
      requestAnimationFrame(animate);
      if (mesh) {
        spinAngle      += 0.008 + scrollVelocity * 0.025;
        scrollVelocity *= 0.92;

        mesh.rotation.y = spinAngle;
        mesh.rotation.z = pos.z_rot;
        mesh.position.x = pos.x;
        // Bob amplitude scales with ball size so it looks natural when tiny
        mesh.position.y = pos.targetY + pos.bobY * pos.scale;
        mesh.scale.setScalar(baseScale * pos.scale);
      }
      renderer.render(scene, camera);
    }
    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBasketball, { once: true });
  } else {
    initBasketball();
  }
</script>

<style>
  .bball-canvas-fixed {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 4;
    display: block;
  }
</style>
